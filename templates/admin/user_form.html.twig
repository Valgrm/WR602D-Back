{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="header">
    <h2>{{ user ? 'Modifier' : 'Ajouter' }} un utilisateur</h2>
    <a href="{{ path('admin_users') }}" class="btn btn-secondary">Retour</a>
</div>
<div class="card" style="max-width: 480px">
    <form method="post">
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="{{ user ? user.email }}" required>
        </div>
        <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" value="{{ user ? user.username }}" required>
        </div>
        <div class="form-group">
            <label>Mot de passe {% if user %}(laisser vide pour ne pas changer){% endif %}</label>
            <input type="password" name="password" {% if not user %}required{% endif %}>
        </div>
        <div class="form-group">
            <label>Rôle</label>
            <select name="role">
                <option value="user" {% if user and 'ROLE_ADMIN' not in user.roles %}selected{% endif %}>Utilisateur</option>
                <option value="admin" {% if user and 'ROLE_ADMIN' in user.roles %}selected{% endif %}>Administrateur</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Enregistrer</button>
    </form>
</div>
{% endblock %}
