{% extends 'admin/base.html.twig' %}

{% block content %}
<div class="header">
    <h2>{{ game ? 'Modifier' : 'Ajouter' }} une partie</h2>
    <a href="{{ path('admin_games') }}" class="btn btn-secondary">Retour</a>
</div>
<div class="card" style="max-width: 480px">
    <form method="post">
        <div class="form-group">
            <label>Score</label>
            <input type="number" name="score" value="{{ game ? game.score }}" required>
        </div>
        <div class="form-group">
            <label>Utilisateur</label>
            <select name="user_id">
                <option value="">— Aucun —</option>
                {% for user in users %}
                <option value="{{ user.id }}" {% if game and game.user and game.user.id == user.id %}selected{% endif %}>
                    {{ user.username }} ({{ user.email }})
                </option>
                {% endfor %}
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Enregistrer</button>
    </form>
</div>
{% endblock %}
